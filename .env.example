# ============================================
# CGM IoT Platform — Environment Template
# Copy to .env and fill in your values
# ============================================

POSTGRES_DB=cgm_platform
POSTGRES_USER=cgm_user
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://cgm_user:CHANGE_ME@postgres:5432/cgm_platform
JWT_SECRET=CHANGE_ME
BACKEND_PORT=8000

MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=1883

ENV=development

# Edge Simulator
EDGE_INTERVAL_SECONDS=5
EDGE_PATIENT_ID=PAT-001
EDGE_DEVICE_ID=DEX-G6-001
EDGE_CSV_PATH=data/sample.csv
# Column mapping (adapt to your CSV)
COL_TIMESTAMP=timestamp
COL_GLUCOSE=glucose
